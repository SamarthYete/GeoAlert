# AkashDrishti — Environment Variables
# Copy this file to .env and fill in your values

# --- Satellite APIs ---
# Sentinel Hub / Copernicus Data Space (CDSE)
SENTINEL_CLIENT_ID=your_client_id_here
SENTINEL_CLIENT_SECRET=your_client_secret_here
SENTINEL_INSTANCE_ID=your_instance_id_here

# Alternatively use SentinelHub SH_INSTANCE_ID:
SH_INSTANCE_ID=your_sh_instance_id

# --- Email Alerts (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
ALERT_RECIPIENT=recipient@example.com

# --- App ---
# In production, set this to false
DEBUG=true
